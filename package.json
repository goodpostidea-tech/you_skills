{
  "name": "you-skills",
  "version": "0.1.2",
  "description": "Visual manager for local AI skills (Codex / Cursor / OpenClaw, etc.)",
  "type": "module",
  "main": "dist/server/index.js",
  "bin": {
    "you-skills": "./dist/cli.js"
  },
  "scripts": {
    "build": "npm-run-all build:client build:server",
    "build:client": "vite build --config client/vite.config.ts",
    "build:server": "tsc -p tsconfig.server.json",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsc -p tsconfig.server.json --watch & node dist/server/index.js",
    "dev:client": "vite --config client/vite.config.ts",
    "start": "node dist/cli.js",
    "preview": "node dist/server/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "skills",
    "codex",
    "openclaw",
    "visualizer",
    "local"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goodpostidea-tech/you_skills.git"
  },
  "bugs": {
    "url": "https://github.com/goodpostidea-tech/you_skills/issues"
  },
  "homepage": "https://github.com/goodpostidea-tech/you_skills#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@heroicons/vue": "^2.2.0",
    "dompurify": "^3.3.1",
    "express": "^4.21.0",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.4",
    "open": "^10.0.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.0.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vue": "^3.5.0",
    "npm-run-all": "^4.1.5"
  }
}
